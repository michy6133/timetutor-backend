NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/timetutor_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-super-secret-key-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=TimeTutor <noreply@timetutor.app>

# Frontend
FRONTEND_URL=http://localhost:4200
MAGIC_LINK_BASE_URL=http://localhost:4200/teacher

# Magic token TTL (heures)
MAGIC_TOKEN_TTL_HOURS=72

# Redis slot lock TTL (secondes)
SLOT_LOCK_TTL_SECONDS=30
