NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/timetutor_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT — access token court + refresh token rotatif
JWT_SECRET=change-this-super-secret-key-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another-super-secret-key-for-refresh-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Cookies (true en prod HTTPS)
COOKIE_SECURE=false

# Email (Nodemailer / SMTP)
# Gmail : activer "Mots de passe des applications" dans la sécurité du compte.
# Pas de guillemets ni d'espaces autour du = dans .env
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=TimeTutor <your@email.com>

# Frontend
FRONTEND_URL=http://localhost:4200
MAGIC_LINK_BASE_URL=http://localhost:4200/teacher

# Magic token TTL (heures)
MAGIC_TOKEN_TTL_HOURS=72

# Redis slot lock TTL (secondes)
SLOT_LOCK_TTL_SECONDS=30

# Twilio (SMS / WhatsApp) — optionnel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
TWILIO_MESSAGING_ENABLED=false

# FedaPay (paiements MTN MoMo, Moov Money, carte)
FEDAPAY_SECRET_KEY=sk_sandbox_your_key
FEDAPAY_PUBLIC_KEY=pk_sandbox_your_key
FEDAPAY_ENV=sandbox
